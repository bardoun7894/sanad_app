rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /receipts/{userId}/{paymentId}/{allPaths=**} {
      allow read: if request.auth != null && (
        request.auth.uid == userId ||
        request.auth.token.admin == true ||
        request.auth.token.email == 'mbardouni44@gmail.com' ||
        request.auth.token.email == 'sanadpsy@gmail.com' ||
        request.auth.uid == 'LUAqWpsZf8S8Qf020gaWB9wRSD82' ||
        request.auth.uid == '45VN8ZuxncaU65FIjx4PN6YSGP02' ||
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    match /profile_photos/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    // The app writes the user photo as a FLAT object: profile_photos/<uid>.jpg
    // (profile_provider.dart). Allow the owner (filename starts with their uid)
    // and admins. Additive — does not loosen the sub-folder rule above.
    match /profile_photos/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && (
        fileName.matches(request.auth.uid + '[.].*') ||
        request.auth.token.admin == true ||
        request.auth.token.email == 'mbardouni44@gmail.com' ||
        request.auth.token.email == 'sanadpsy@gmail.com' ||
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    // Content images uploaded from admin CMS (articles, exercises, podcast covers).
    // Public read so any user app can show them; only admin can write/delete.
    // isAdmin mirrors firestore.rules: custom claim > super-admin UID > Firestore role doc.
    match /content_images/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && (
        request.auth.token.admin == true ||
        request.auth.token.email == 'mbardouni44@gmail.com' ||
        request.auth.token.email == 'sanadpsy@gmail.com' ||
        request.auth.uid == 'LUAqWpsZf8S8Qf020gaWB9wRSD82' ||
        request.auth.uid == '45VN8ZuxncaU65FIjx4PN6YSGP02' ||
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    // Landing-page media (hero video + poster) uploaded from admin settings.
    // Public read so the marketing site can stream them; only admin can write.
    match /landing/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && (
        request.auth.token.admin == true ||
        request.auth.token.email == 'mbardouni44@gmail.com' ||
        request.auth.token.email == 'sanadpsy@gmail.com' ||
        request.auth.uid == 'LUAqWpsZf8S8Qf020gaWB9wRSD82' ||
        request.auth.uid == '45VN8ZuxncaU65FIjx4PN6YSGP02' ||
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    // Therapist profile photos.
    // A therapist uploads their own photo under therapist_photos/{therapistId}/...
    // where therapistId == their auth uid (therapist_auth_service.dart passes the
    // signed-in uid). Admins may also write here.
    match /therapist_photos/{therapistId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && (
        request.auth.uid == therapistId ||
        request.auth.token.admin == true ||
        request.auth.token.email == 'mbardouni44@gmail.com' ||
        request.auth.token.email == 'sanadpsy@gmail.com' ||
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }
    // Flat admin uploads from the therapist form: therapist_photos/<file>.jpg
    match /therapist_photos/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && (
        request.auth.token.admin == true ||
        request.auth.token.email == 'mbardouni44@gmail.com' ||
        request.auth.token.email == 'sanadpsy@gmail.com' ||
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    // Support-chat attachments (images sent in the دعم سند conversation).
    // Path: support_chats/<userId>/<file>. The two participants — the chat
    // owner and admins — may read and write; nobody else. Mirrors the
    // support_chats Firestore rule (auth.uid == chatId || isAdmin).
    match /support_chats/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && (
        request.auth.uid == userId ||
        request.auth.token.admin == true ||
        request.auth.token.email == 'mbardouni44@gmail.com' ||
        request.auth.token.email == 'sanadpsy@gmail.com' ||
        request.auth.uid == 'LUAqWpsZf8S8Qf020gaWB9wRSD82' ||
        request.auth.uid == '45VN8ZuxncaU65FIjx4PN6YSGP02' ||
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    // Default deny
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
